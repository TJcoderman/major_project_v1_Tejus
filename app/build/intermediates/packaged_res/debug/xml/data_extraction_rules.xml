<?xml version="1.0" encoding="utf-8"?>
<!--
   Behavioral data should NOT be backed up for security reasons.
   This prevents behavioral profiles from being transferred to other devices.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>

